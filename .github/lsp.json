{
  "lspServers": {
    "typescript": {
      "command": "npx",
      "args": ["--no", "typescript-language-server", "--", "--stdio"],
      "fileExtensions": {
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact"
      }
    }
  }
}
